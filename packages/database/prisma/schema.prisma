// Conscious Slovenia — Database Schema v2
// Stack: Prisma + PostgreSQL (Supabase-ready)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum EventCategory {
  YOGA
  MEDITATION
  BREATHWORK
  SOUND_BATH
  CACAO_CEREMONY
  RETREAT
  WORKSHOP
  DANCE
  TANTRA
  HEALING
  OTHER
}

enum EventStatus {
  PENDING_REVIEW
  APPROVED
  FEATURED
  REJECTED
  ARCHIVED
}

enum EventSource {
  FACEBOOK_GROUP
  DIRECT_SUBMISSION
  MANUAL
}

enum OrganizerTier {
  FREE
  PREMIUM
  PARTNER
}

enum DraftStatus {
  DRAFT
  SCHEDULED
  SENT
  FAILED
}

// ─────────────────────────────────────────────────────────────────────────────
// ORGANIZERS
// ─────────────────────────────────────────────────────────────────────────────

model Organizer {
  id          String        @id @default(cuid())
  name        String
  email       String?       @unique
  phone       String?
  instagram   String?
  website     String?
  facebookUrl String?
  bio         String?
  avatarUrl   String?
  rating      Float         @default(0)
  reviewCount Int           @default(0)
  verified    Boolean       @default(false)
  tier        OrganizerTier @default(FREE)
  events      Event[]

  // Rich bio — researched Wikipedia-style biography, auto-updated on each new event
  richBio             String?
  richBioResearchedAt DateTime?

  // Research & outreach fields
  researchedAt    DateTime?
  researchNotes   String?
  contactEmail    String?
  contactPhone    String?
  outreachSentAt  DateTime?
  outreachStatus  String?   @default("PENDING")  // PENDING | SENT | REPLIED | OPTED_OUT

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([tier])
  @@index([outreachStatus])
}

// ─────────────────────────────────────────────────────────────────────────────
// VENUES
// ─────────────────────────────────────────────────────────────────────────────

model Venue {
  id       String   @id @default(cuid())
  name     String
  slug     String?  @unique
  address  String?
  city     String   @default("Ljubljana")
  region   String?
  country  String   @default("Slovenia")
  lat      Float?
  lng      Float?
  website  String?
  imageUrl String?
  events   Event[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city])
}

// ─────────────────────────────────────────────────────────────────────────────
// EVENTS
// ─────────────────────────────────────────────────────────────────────────────

model Event {
  id    String  @id @default(cuid())
  slug  String? @unique

  titleSl       String?
  titleEn       String
  descriptionSl String?
  descriptionEn String
  shortDescEn   String?

  date    DateTime
  endDate DateTime?

  price     Float?
  priceNote String?
  currency  String  @default("EUR")

  category EventCategory @default(OTHER)
  tags     String[]

  imageUrl  String?
  sourceUrl String?     @unique
  source    EventSource @default(FACEBOOK_GROUP)

  status   EventStatus @default(PENDING_REVIEW)
  featured Boolean     @default(false)

  // Analytics
  viewCount Int @default(0)

  rawText      String?
  aiProcessed  Boolean @default(false)
  aiConfidence Float?

  organizerId String?
  organizer   Organizer? @relation(fields: [organizerId], references: [id])
  venueId     String?
  venue       Venue?     @relation(fields: [venueId], references: [id])
  venueName   String?

  newsletterDrafts NewsletterDraft[] @relation("EventToNewsletter")
  revenueLogs      RevenueLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([category])
  @@index([status])
  @@index([featured])
  @@index([aiProcessed])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// NEWSLETTER DRAFTS
// ─────────────────────────────────────────────────────────────────────────────

model NewsletterDraft {
  id          String      @id @default(cuid())
  title       String
  subjectLine String?
  previewText String?
  contentMd   String
  contentHtml String?
  status      DraftStatus @default(DRAFT)
  scheduledFor DateTime?
  publishedAt  DateTime?
  externalId   String?
  platform     String?
  weekNumber   Int?
  year         Int?
  weekStart    DateTime?
  weekEnd      DateTime?
  events       Event[]    @relation("EventToNewsletter")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([status])
  @@index([year, weekNumber])
}

// ─────────────────────────────────────────────────────────────────────────────
// SUBSCRIBERS
// ─────────────────────────────────────────────────────────────────────────────

model Subscriber {
  id          String          @id @default(cuid())
  email       String          @unique
  firstName   String?
  lastName    String?
  active      Boolean         @default(true)
  source      String?
  preferences EventCategory[]   // event categories subscriber is interested in
  cities      String[]          // city names subscriber wants events from
  externalId  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([active])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// SUBMISSIONS — paid direct submissions
// ─────────────────────────────────────────────────────────────────────────────

model Submission {
  id              String   @id @default(cuid())
  email           String
  formData        Json
  eventId         String?  @unique
  paid            Boolean  @default(false)
  stripeSessionId String?
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// PIPELINE RUNS — track every automated scrape+process execution
// ─────────────────────────────────────────────────────────────────────────────

model PipelineRun {
  id               String   @id @default(cuid())
  runId            String   @unique
  scraped          Int      @default(0)   // total posts scraped from all groups
  deduplicated     Int      @default(0)   // new posts (not already in DB)
  processed        Int      @default(0)   // sent to AI
  saved            Int      @default(0)   // successfully saved to DB
  autoApproved     Int      @default(0)   // auto-approved (high confidence)
  skipped          Int      @default(0)   // low confidence, skipped
  errors           String[]
  totalTokens      Int      @default(0)
  cachedTokens     Int      @default(0)
  estimatedCostUsd Float    @default(0)
  durationMs       Int      @default(0)
  trigger          String   @default("cron") // "cron" | "manual" | "webhook"
  createdAt        DateTime @default(now())

  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// COST LOG — track every external API cost
// ─────────────────────────────────────────────────────────────────────────────

model CostLog {
  id          String   @id @default(cuid())
  service     String   // "anthropic" | "beehiiv" | "stripe" | "vercel" | "supabase"
  operation   String   // "event_extraction" | "newsletter_publish" | "submission"
  amountUsd   Float    // cost in USD
  units       Int?     // tokens, API calls, etc.
  metadata    Json?
  pipelineRunId String?
  createdAt   DateTime @default(now())

  @@index([service])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// REVENUE LOG — track every payment received
// ─────────────────────────────────────────────────────────────────────────────

model RevenueLog {
  id              String   @id @default(cuid())
  type            String   // "featured_listing" | "basic_listing" | "sponsorship" | "pass"
  amountEur       Float
  stripePaymentId String?  @unique
  eventId         String?
  event           Event?   @relation(fields: [eventId], references: [id])
  submissionId    String?
  description     String?
  createdAt       DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}
