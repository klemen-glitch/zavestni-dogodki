// Conscious Slovenia — Database Schema
// Stack: Prisma + PostgreSQL (Supabase-ready)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum EventCategory {
  YOGA
  MEDITATION
  BREATHWORK
  SOUND_BATH
  CACAO_CEREMONY
  RETREAT
  WORKSHOP
  DANCE
  TANTRA
  HEALING
  OTHER
}

enum EventStatus {
  PENDING_REVIEW // scraped, not yet approved
  APPROVED       // live on the directory
  FEATURED       // paid featured placement
  REJECTED       // failed moderation
  ARCHIVED       // past events
}

enum EventSource {
  FACEBOOK_GROUP    // auto-scraped from FB group
  DIRECT_SUBMISSION // organizer submitted directly (paid)
  MANUAL            // manually entered by admin
}

enum OrganizerTier {
  FREE    // basic listing
  PREMIUM // paid, unlocks analytics + priority
  PARTNER // venue/sponsor partnership
}

enum DraftStatus {
  DRAFT
  SCHEDULED
  SENT
  FAILED
}

// ─────────────────────────────────────────────────────────────────────────────
// ORGANIZERS — facilitators, teachers, event creators
// ─────────────────────────────────────────────────────────────────────────────

model Organizer {
  id          String        @id @default(cuid())
  name        String
  email       String?       @unique
  phone       String?
  instagram   String?
  website     String?
  facebookUrl String?
  bio         String?
  avatarUrl   String?
  rating      Float         @default(0)
  reviewCount Int           @default(0)
  verified    Boolean       @default(false)
  tier        OrganizerTier @default(FREE)

  events    Event[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tier])
}

// ─────────────────────────────────────────────────────────────────────────────
// VENUES — physical locations (studios, parks, retreat centers)
// ─────────────────────────────────────────────────────────────────────────────

model Venue {
  id      String  @id @default(cuid())
  name    String
  slug    String? @unique
  address String?
  city    String  @default("Ljubljana")
  region  String?
  country String  @default("Slovenia")
  lat     Float?
  lng     Float?
  website String?
  imageUrl String?

  events    Event[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city])
}

// ─────────────────────────────────────────────────────────────────────────────
// EVENTS — the core entity
// ─────────────────────────────────────────────────────────────────────────────

model Event {
  id   String @id @default(cuid())
  slug String? @unique

  // Bilingual content (Slovenian + English)
  titleSl       String?
  titleEn       String
  descriptionSl String?
  descriptionEn String
  shortDescEn   String? // max 160 chars for cards / newsletter previews

  // Scheduling
  date    DateTime
  endDate DateTime?

  // Pricing
  price    Float?  // null = unknown, 0 = free
  priceNote String? // "Po srcu / Heart donation", "20–30€ sliding scale"
  currency  String  @default("EUR")

  // Classification
  category EventCategory @default(OTHER)
  tags     String[]

  // Media & links
  imageUrl  String?
  sourceUrl String?     @unique // original FB post URL
  source    EventSource @default(FACEBOOK_GROUP)

  // Status & visibility
  status   EventStatus @default(PENDING_REVIEW)
  featured Boolean     @default(false)

  // AI processing metadata
  rawText      String? // original scraped text
  aiProcessed  Boolean @default(false)
  aiConfidence Float?  // 0.0–1.0

  // Relations
  organizerId String?
  organizer   Organizer? @relation(fields: [organizerId], references: [id])
  venueId     String?
  venue       Venue?     @relation(fields: [venueId], references: [id])
  venueName   String?    // fallback plain-text location if venue not in DB

  newsletterDrafts NewsletterDraft[] @relation("EventToNewsletter")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([category])
  @@index([status])
  @@index([featured])
  @@index([aiProcessed])
}

// ─────────────────────────────────────────────────────────────────────────────
// NEWSLETTER DRAFTS — compiled weekly editions
// ─────────────────────────────────────────────────────────────────────────────

model NewsletterDraft {
  id          String @id @default(cuid())
  title       String // e.g. "Zavestni Dogodki — 10.–16. junij 2026"
  subjectLine String? // email subject (A/B testable)
  previewText String? // email preview snippet

  contentMd   String // Markdown source
  contentHtml String? // rendered HTML (optional, for direct API push)

  status       DraftStatus @default(DRAFT)
  scheduledFor DateTime?
  publishedAt  DateTime?

  // External platform IDs after publishing
  externalId String? // Beehiiv post_id or Ghost post ID
  platform   String? // "beehiiv" | "ghost"

  // Edition metadata
  weekNumber Int?
  year       Int?
  weekStart  DateTime?
  weekEnd    DateTime?

  events Event[] @relation("EventToNewsletter")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([year, weekNumber])
}

// ─────────────────────────────────────────────────────────────────────────────
// SUBSCRIBERS — email list (mirror of Beehiiv, for local analytics)
// ─────────────────────────────────────────────────────────────────────────────

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  firstName String?
  lastName  String?
  active    Boolean  @default(true)
  source    String?  // "beehiiv", "landing_page", "event_signup"

  // Category preferences for personalized digests
  preferences EventCategory[]

  externalId String? // Beehiiv subscriber ID
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([active])
}

// ─────────────────────────────────────────────────────────────────────────────
// SUBMISSIONS — direct paid submissions bypassing FB group
// ─────────────────────────────────────────────────────────────────────────────

model Submission {
  id    String @id @default(cuid())
  email String

  // Raw submission data from the form
  formData Json

  // Linked event after approval
  eventId String? @unique

  paid       Boolean @default(false)
  stripeSessionId String?

  status    String   @default("pending") // pending | approved | rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
